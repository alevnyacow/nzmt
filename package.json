{
  "name": "@alevnyacow/nzmt",
  "version": "0.10.1",
  "description": "Next Zod Modules Toolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/alevnyacow/nzmt.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "nzmt": "./bin/cli.js"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "biome format --write",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@rslib/core": "^0.20.0",
    "@rstest/adapter-rslib": "^0.2.1",
    "@rstest/core": "^0.9.0",
    "@types/node": "^24.12.0",
    "next": "^16.1.6",
    "zod": "^4.3.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "next": ">=13 <17",
    "zod": ">=4 <5",
    "inversify": ">=7 <9",
    "reflect-metadata": "^0.2.2"
  },
  "private": false
}
